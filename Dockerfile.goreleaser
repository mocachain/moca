# Dockerfile.goreleaser
# This Dockerfile is used by GoReleaser to build multi-arch Docker images
# GoReleaser handles the compilation and copies the pre-built binary
FROM golang:1.26.4-bookworm

RUN apt-get update -y && apt-get install -y --no-install-recommends ca-certificates jq && rm -rf /var/lib/apt/lists/*

WORKDIR /root

# GoReleaser will copy the pre-built binary here
COPY bin/mocad /usr/bin/mocad

ENTRYPOINT ["mocad"]
